{
  "name": "norway-open-data-sdk",
  "version": "0.5.1",
  "description": "One TypeScript interface for Norway's open public APIs.",
  "keywords": [
    "norway",
    "norge",
    "open-data",
    "public-data",
    "government-data",
    "ssb",
    "brreg",
    "kartverket",
    "entur",
    "met",
    "data-norge",
    "norges-bank",
    "stortinget",
    "nvdb",
    "nve",
    "typescript",
    "sdk"
  ],
  "license": "MIT",
  "author": "Norway Open Data SDK contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamkm1/Norway-Open-Data.git"
  },
  "homepage": "https://github.com/iamkm1/Norway-Open-Data#readme",
  "bugs": {
    "url": "https://github.com/iamkm1/Norway-Open-Data/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE",
    "PROVIDERS.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md",
    "docs/examples.md",
    "docs/architecture.md",
    "docs/capabilities.md",
    "docs/testing.md",
    "docs/adding-a-provider.md",
    "docs/api-stability.md",
    "docs/release-checklist.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": "0.28.1"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:package": "tsx scripts/test-package.ts",
    "test:live": "cross-env RUN_LIVE_TESTS=true vitest run tests/live",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "prettier --check . && eslint . && tsc --noEmit && vitest run --coverage && tsup && typedoc && tsx scripts/check-portability.ts && tsx scripts/test-package.ts",
    "check:portability": "tsx scripts/check-portability.ts",
    "docs": "typedoc",
    "changeset": "changeset",
    "prepublishOnly": "npm run verify",
    "smoke": "tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.2.4"
  }
}
